# ── WAJIB DIISI ─────────────────────────────────────────────

# Token bot dari @BotFather di Telegram
BOT_TOKEN=ISI_TOKEN_BOT_KAMU_DISINI

# Telegram User ID admin (pisahkan dengan koma jika lebih dari satu)
# Cara lihat User ID: forward pesan ke @userinfobot
ADMIN_IDS=123456789,987654321

# ── PEMBAYARAN (Wajib jika pakai fitur VIP & Top Up) ────────

# Info rekening untuk pembayaran VIP
# Format: Nama Bank: Nomor Rekening a/n Nama
VIP_TRANSFER_INFO=Bank BCA: 1234567890 a/n Nama Kamu

# Info rekening untuk Top Up koin
TOPUP_TRANSFER_INFO=Bank BCA: 1234567890 a/n Nama Kamu

# ── OPSIONAL ────────────────────────────────────────────────

# ID channel Telegram untuk notifikasi aktivitas market
# (kosongkan jika tidak ingin notifikasi)
# Format: angka negatif, contoh: -1001234567890
MARKET_CHANNEL_ID=

# Link channel official bot (tampil di menu /start)
OFFICIAL_CHANNEL=https://t.me/channel_kamu

# Link grup official bot (tampil di menu /start)
OFFICIAL_GROUP=https://t.me/grup_kamu
